{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/transaction", "dest": "/api/transaction.py" },
    { "src": "/api/summary", "dest": "/api/summary.py" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
