{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/transaction", "dest": "/api/transaction.py" },
    { "src": "/api/summary", "dest": "/api/summary.py" },
    { "src": "/api/activer", "dest": "/api/activer.py" },
    { "src": "/api/verifier", "dest": "/api/verifier.py" },
    { "src": "/api/admin_generer_code", "dest": "/api/admin_generer_code.py" },
    { "src": "/api/admin_liste", "dest": "/api/admin_liste.py" },
    { "src": "/api/renouveler", "dest": "/api/renouveler.py" },
    { "src": "/api/dashboard_connexion", "dest": "/api/dashboard_connexion.py" },
    { "src": "/api/definir_mot_de_passe", "dest": "/api/definir_mot_de_passe.py" },
    { "src": "/api/mois_disponibles", "dest": "/api/mois_disponibles.py" },
    { "src": "/api/modifier_boutique", "dest": "/api/modifier_boutique.py" },
    { "src": "/api/statistiques", "dest": "/api/statistiques.py" },
    { "src": "/api/recuperer_acces", "dest": "/api/recuperer_acces.py" },
    { "src": "/api/admin_stats", "dest": "/api/admin_stats.py" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/activation", "dest": "/activation.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
